{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Singula",
  "version": "0.1.0",
  "identifier": "com.sift.duplicateintelligence",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Singula — File Intelligence",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"]
      }
    },
    "longDescription": "Persistent, history-aware duplicate-file intelligence for Windows. Scans drives and folders, builds a durable index that survives drive disconnects, and helps you safely reclaim space with full audit and keep-at-least-one-copy safety.",
    "shortDescription": "Persistent duplicate & file-index intelligence."
  }
}
