<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy auto-backup rules (android:fullBackupContent) used on API levels below
    31. Application preferences (DataStore) are backed up; the encrypted Vault
    directory is excluded because its contents are protected by a device-bound
    key that cannot be restored on another device.

    See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>

    <!-- Exclude the encrypted vault storage; keys are not portable across devices. -->
    <exclude
        domain="file"
        path="vault" />

    <!-- Remote passwords/tokens and their non-secret endpoint metadata are device-local. Restoring
         either half on another device creates a misleading or unusable connection state. -->
    <exclude domain="sharedpref" path="jupiter_remote_credentials.xml" />
    <exclude domain="sharedpref" path="jupiter_vault_pin.xml" />
    <exclude domain="file" path="datastore/jupiter_connections.preferences_pb" />

    <!-- The index can contain private file metadata and is rebuilt safely from the device. -->
    <exclude domain="database" path="jupiter_index.db" />
    <exclude domain="database" path="jupiter_index.db-wal" />
    <exclude domain="database" path="jupiter_index.db-shm" />

</full-backup-content>
