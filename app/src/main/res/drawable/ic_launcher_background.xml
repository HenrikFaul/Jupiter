<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon background layer.

    A 108x108dp vector filled with a vertical indigo gradient that matches the
    Jupiscan brand. The full 108dp canvas guarantees the background covers the
    icon for every device mask (circle, squircle, rounded square, etc.).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt"
            name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="0"
                android:endX="54"
                android:endY="108">
                <item android:offset="0.0" android:color="#FF5560D8" />
                <item android:offset="1.0" android:color="#FF3A45B0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
