<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Storage permissions.

        On API <= 32 (Android 12L and below) classic read access to shared storage
        is granted through READ_EXTERNAL_STORAGE. From API 33 (Tiramisu) onward
        broad media access is handled through MANAGE_EXTERNAL_STORAGE (All Files
        Access) for a file manager, so the legacy read permission is capped.
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!--
        Legacy write access was only meaningful up to API 29 (Q). After that
        scoped storage / All Files Access supersede it, so the permission is
        capped to avoid requesting a no-op grant on newer platforms.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!--
        All Files Access. Required for a general purpose file manager to browse
        and operate across the whole external storage volume on API 30+ (R).
    -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Biometric unlock for the encrypted Vault feature. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Required to post foreground/operation progress notifications on API 33+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".JupiterApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Jupiter"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Jupiter"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            FileProvider used to share files (open-with / share intents) without
            exposing raw file:// URIs. The authority is derived from the build's
            applicationId so debug (.debug suffix) and release variants do not
            collide when installed side by side.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
